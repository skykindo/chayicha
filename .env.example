# ============================================================
# Supabase PostgreSQL — 从 Supabase Dashboard 复制
# Project Settings → Database → Connection string
# ============================================================

# 事务池化 URL（Next.js / Vercel Serverless 推荐）
# Connect → Transaction pooler → URI，端口 6543，末尾加 ?pgbouncer=true
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# 直连 URL（国内 Windows 推荐 Session pooler，端口 5432）
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ============================================================
# Supabase Client（Phase 2 前端可选，用于 Realtime / Auth）
# Project Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================================
# 爬虫层（Phase 1）
# ============================================================
SCRAPER_CONCURRENCY=1
SCRAPER_HEADLESS=true
SCRAPER_REQUEST_DELAY_MS=3000
# 磁盘不足时设为 true，直接用本机 Chrome，无需 npm run scraper:browser
SCRAPER_USE_SYSTEM_CHROME=true

# ============================================================
# 轨道 B：AI 视觉（集换社 / 闲鱼小程序）
# ============================================================
# 识图：gemini | doubao（DeepSeek 官方 API 不支持 image_url）
VISION_PROVIDER=gemini
GEMINI_API_KEY="your-gemini-api-key"
# 豆包/火山方舟识图（VISION_PROVIDER=doubao 时必填）
# DOUBAO_API_KEY="your-ark-api-key"
# DOUBAO_MODEL=doubao-1-5-vision-pro-32k-250115
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DeepSeek 仅文本，勿用于 VISION 识图
# DEEPSEEK_API_KEY="your-deepseek-api-key"
VISION_PYTHON=python
VISION_MOCK=true
